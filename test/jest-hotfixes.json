{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "roots": ["<rootDir>/src", "<rootDir>/test"],
  "testRegex": "test/common/(audit-sanitize|extract-ip|audit-service)\\..*spec\\.ts$|test/auth/(consumer-login-audit|company-login-audit)\\.e2e-spec\\.ts$",
  "transform": { "^.+\\.(t|j)s$": "ts-jest" },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1"
  },
  "collectCoverageFrom": ["src/common/**/*.(t|j)s", "src/modules/auth/**/*.(t|j)s"],
  "coverageDirectory": "coverage-hotfixes",
  "testEnvironment": "node",
  "testTimeout": 30000
}
