# Ambiente de teste local (unit + integração/E2E)
# Copiar para .env antes de rodar localmente: cp .env.test .env
# Valores fixos são somente para teste. Nunca reutilizar em produção.
NODE_ENV=test

# PostgreSQL local
# Subir com: docker compose -f docker-compose.test.yml up -d
DATABASE_URL=postgresql://trustcheck:trustcheck@localhost:5432/trustcheck_e2e

# Redis local
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT de teste
JWT_SECRET=test-jwt-secret-local-not-for-prod
JWT_REFRESH_SECRET=test-refresh-secret-local-not-for-prod
JWT_EXPIRES_IN=15m

# Assinatura interna de teste para endpoints system/internal
INTERNAL_HMAC_SECRET=test-internal-hmac-secret-local-not-for-prod

# OTP
OTP_LENGTH=6
OTP_EXPIRATION_SECONDS=300

# Trusted proxy desabilitado em NODE_ENV=test — extractClientIp ignora XFF
# TRUSTED_PROXY_SECRET=

PORT=3000
