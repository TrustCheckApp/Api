# Ambiente de teste local (unit + integration sem Docker)
# Copiar para .env antes de rodar: cp .env.test .env
NODE_ENV=test

# PostgreSQL local (deve estar rodando com: docker compose -f docker-compose.e2e.yml up postgres)
DATABASE_URL=postgresql://trustcheck:trustcheck@localhost:5432/trustcheck_e2e

# Redis local
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (valores fixos para teste — NUNCA usar em produção)
JWT_SECRET=test-jwt-secret-local-not-for-prod
JWT_REFRESH_SECRET=test-refresh-secret-local-not-for-prod
JWT_EXPIRES_IN=15m

# OTP
OTP_LENGTH=6
OTP_EXPIRATION_SECONDS=300

# Trusted proxy (desabilitado em NODE_ENV=test — extractClientIp ignora XFF)
# TRUSTED_PROXY_SECRET=

PORT=3000
