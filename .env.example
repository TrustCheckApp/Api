# Variáveis de ambiente — NÃO commitar este arquivo
# Copie para .env e preencha os valores reais

# Aplicação
NODE_ENV=development
PORT=3000

# Banco de dados PostgreSQL
DATABASE_URL="postgresql://trustcheck:senha@localhost:5432/trustcheck_dev"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=troque-por-segredo-forte-aqui
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=troque-por-refresh-segredo-forte
JWT_REFRESH_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=1h

# OAuth2 Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# OAuth2 Apple (Sign in with Apple)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

# OTP — provider isolado em Integrations (adapter pattern)
# OTP_PROVIDER=log           # dev: apenas loga (LogOtpProvider)
# OTP_PROVIDER=sendgrid      # prod: e-mail via Integrations
OTP_EXPIRATION_SECONDS=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_HOURLY=3
OTP_RATE_LIMIT_BLOCK_SECONDS=1800

# Email (SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@trustcheck.com.br

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_MEDIA=trustcheck-media-dev

# Versão do Termo Legal
LEGAL_TERM_VERSION=1.0

# Redis URL (alternativa ao host/port individual)
REDIS_URL=redis://localhost:6379

# E2E Tests
DATABASE_URL_TEST=postgresql://trustcheck:trustcheck_test@localhost:5433/trustcheck_test
REDIS_URL_TEST=redis://localhost:6380

# Assinatura HMAC para chamadas internas (system)
# Geração: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Inclua no header X-Internal-Signature: hmac-sha256 do body serializado como JSON
INTERNAL_HMAC_SECRET=troque-por-segredo-hmac-forte-aqui
