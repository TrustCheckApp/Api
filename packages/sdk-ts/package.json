{
  "name": "@trustcheck/sdk-ts",
  "version": "1.0.0",
  "description": "SDK TypeScript gerado a partir do contrato OpenAPI oficial da TrustCheck API",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "openapi-ts -i ../../openapi/openapi.yaml -o ./src",
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist src",
    "check": "npm run generate && npm run build"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.2.4"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.97.0",
    "typescript": "^5.4.2",
    "rimraf": "^5.0.5"
  }
}
