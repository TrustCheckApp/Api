{
  "name": "@trustcheck/sdk-ts",
  "version": "1.4.0",
  "description": "SDK TypeScript gerado a partir do openapi.yaml da TrustCheck API",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "generate": "openapi-ts --input ../../openapi/openapi.yaml --output ./src --client @hey-api/client-fetch",
    "build": "tsc",
    "clean": "rimraf dist src"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.2.4"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.47.0",
    "typescript": "^5.4.2",
    "rimraf": "^5.0.5"
  }
}
